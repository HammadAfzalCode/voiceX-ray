# Backend
PORT=3000
TTS_MODE=client

# LLM (required for Phase 2+)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=openai/gpt-4o-mini

# TTS (required for Phase 3+ when TTS_MODE=elevenlabs)
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...
ELEVENLABS_MODEL=eleven_flash_v2_5

# History
MAX_HISTORY_TURNS=8

# Frontend (Vite env — prefix with VITE_)
VITE_BACKEND_URL=http://localhost:3000
